# Copy to `.env` (backend, git-ignored) and/or `.env.local` (frontend) and fill in.
# On Vercel, set these as project Environment Variables instead.

# --- Backend (FastAPI / Python) ---
# The key used to authenticate with Claude. For the direct Anthropic API this
# is your `sk-ant-...` key; for a gateway (see ANTHROPIC_BASE_URL) it's the
# gateway's subscription key. Optional if users paste a key in ⚙️ Settings.
ANTHROPIC_API_KEY=your-key-or-subscription-key

# Optional: point at a gateway in front of Claude instead of api.anthropic.com
# (e.g. an Azure API Management proxy). When set, ANTHROPIC_API_KEY is sent as
# the gateway's `subscription-key` query parameter.
# ANTHROPIC_BASE_URL=https://your-gateway.azure-api.net/claude/anthropic

# --- Frontend (Next.js middleware) ---
# Shared password for the login gate. If unset, the gate is DISABLED and the
# app is open. Set it to require a password at /login before using the app.
APP_PASSWORD=change-me
