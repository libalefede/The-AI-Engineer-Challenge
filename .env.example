# Copy to `.env` (backend, git-ignored) and/or `.env.local` (frontend) and fill in.
# On Vercel, set these as project Environment Variables instead.

# --- Backend (FastAPI / Python) ---
# Your Anthropic API key. Used by api/index.py to call Claude.
# Optional if users paste their own key in the app's ⚙️ Settings.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Frontend (Next.js middleware) ---
# Shared password for the login gate. If unset, the gate is DISABLED and the
# app is open. Set it to require a password at /login before using the app.
APP_PASSWORD=change-me
